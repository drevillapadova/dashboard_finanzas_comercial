# =====================================================================
# dashboard_finanzas_comercial - Variables de entorno
# Copia este archivo a `.env` y rellena los valores. NO subas .env a git.
# =====================================================================

# --- EVOLTA (login para el ETL Selenium) ---
EVOLTA_USER=
EVOLTA_PASS=

# --- Azure App Registration (Microsoft Graph - client credentials) ---
# Mismo App Registration que ya usan online-deploy y tc-service
# (permiso Sites.ReadWrite.All ya concedido sobre el sitio).
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=tu-client-secret-aqui

# --- SharePoint - ubicacion del Excel del dashboard ---
SHAREPOINT_HOSTNAME=padovasac.sharepoint.com
SHAREPOINT_SITE_PATH=sites/Finanzas
SHAREPOINT_DRIVE_NAME=Documents
SHAREPOINT_DASHBOARD_FOLDER=FINANZAS/TI/AUTOMATIZACIONES/DASHBOARD_FINANZAS_COMERCIAL
SHAREPOINT_DASHBOARD_FILENAME=Dashboard_Finanzas_Comercial.xlsx
